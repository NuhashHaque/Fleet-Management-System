{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "fleet.dlq.v1",
  "title": "Fleet Dead Letter Event v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "trace_id",
    "failed_topic",
    "error_type",
    "error_message",
    "event_time",
    "raw_payload"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "dlq.v1"
    },
    "trace_id": {
      "type": "string",
      "minLength": 8,
      "maxLength": 128
    },
    "failed_topic": {
      "type": "string",
      "minLength": 1
    },
    "error_type": {
      "type": "string",
      "minLength": 1
    },
    "error_message": {
      "type": "string",
      "minLength": 1
    },
    "event_time": {
      "type": "string",
      "format": "date-time"
    },
    "raw_payload": {
      "type": "string",
      "minLength": 1
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
